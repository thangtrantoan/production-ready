# Copy this file to .env.local and fill in real values.
# Only variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# Base URL of the backend API (e.g. FastAPI). No trailing slash.
# The axios instance in src/lib/axios.ts prepends this to every request.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Public URL of this site. Used for SEO metadata / Open Graph in
# src/config/site.config.ts. Set to the production domain when deploying.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
