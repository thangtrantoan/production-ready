# Copy this file to .env and fill in real values.

# Secret used to sign JWTs. Generate a real one:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me

# SQLAlchemy connection string. SQLite for local dev;
# swap to Postgres in production, e.g.:
#   postgresql+psycopg://user:pass@localhost:5432/appdb
DATABASE_URL=sqlite:///./app.db

# Token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Comma-separated list of origins allowed by CORS (the Next.js dev server)
CORS_ORIGINS=http://localhost:3000
